graph TB
    subgraph "Client Layer"
        API[RecommendationEngine API<br/>- recommend&#40;&#41;<br/>- record_interaction&#40;&#41;<br/>- get_statistics&#40;&#41;]
        Cache[Cache Layer<br/>TTL: 300s<br/>Dict-based]
    end
    
    subgraph "Configuration"
        Config[RecommendationConfig<br/>- candidate_pool_size: 1500<br/>- in_network_ratio: 0.4<br/>- out_network_ratio: 0.5<br/>- social_proof_ratio: 0.1<br/>- light_ranking_top_k: 500<br/>- heavy_ranking_top_k: 100<br/>- exploration_strategy<br/>- safety_threshold: 0.7]
    end
    
    subgraph "Step 1: Candidate Sourcing"
        CS[CandidateSourcing<br/>Pipeline Orchestrator<br/>~1500 candidates]
        INS[InNetworkSource<br/>40% - Following Graph<br/>Content from followed authors]
        ONS[OutOfNetworkSource<br/>50% - Discovery<br/>Interest clusters + Trending + Similar users]
        SPS[SocialProofSource<br/>10% - Social Signals<br/>Friend engagement data]
    end
    
    subgraph "Step 2: Light Ranking"
        LR[LightRanker<br/>Fast Feature Extraction<br/>Lightweight scoring<br/>Output: Top 500]
        LF[Light Features:<br/>- Content age<br/>- Engagement velocity<br/>- Author influence<br/>- User-content match]
    end
    
    subgraph "Step 3: Heavy Ranking"
        HR[HeavyRanker<br/>Precise ML-based Ranking<br/>Multi-task predictions<br/>Output: Top 100]
        MTM[MultiTaskModel<br/>Predictions:<br/>- P&#40;like&#41;<br/>- P&#40;retweet&#41;<br/>- P&#40;reply&#41;<br/>- P&#40;click&#41;<br/>- E&#40;dwell_time&#41;<br/>- P&#40;negative&#41;]
        US[UtilityScorer<br/>Weighted Utility:<br/>utility = Σ w_i * P_i]
    end
    
    subgraph "Step 4: Exploration"
        EE[ExplorationEngine<br/>Balance Explore/Exploit<br/>Strategies:<br/>- ε-greedy<br/>- UCB<br/>- Thompson Sampling]
        Stats[Content Stats Tracker<br/>- Impressions<br/>- Rewards<br/>- Success/Failure counts]
    end
    
    subgraph "Step 5: Diversity"
        DI[DiversityInjector<br/>Feed Diversity Constraints<br/>- Topic diversity<br/>- Author diversity<br/>- Content similarity check]
    end
    
    subgraph "Step 6: Safety Filtering"
        SF[SafetyFilter<br/>Multi-detector System<br/>Threshold: 0.7]
        TD[ToxicityDetector<br/>Hate speech detection]
        MD[MisinformationDetector<br/>Fake news detection]
        SD[SpamDetector<br/>Spam pattern detection]
        ND[NSFWDetector<br/>Adult content detection]
    end
    
    subgraph "Step 7: Serving"
        Response[RecommendationResponse<br/>- recommendations<br/>- latency<br/>- metadata]
    end
    
    subgraph "Observability Infrastructure"
        Logger[Logger System<br/>File-based Trace Logging<br/>Component-specific logs]
        Tracer[RequestTracer<br/>Pipeline flow tracing<br/>Request comparison]
        Analyzer[LogAnalyzer<br/>Metrics & Analysis<br/>Performance insights]
    end
    
    API -->|initialize with| Config
    API -->|check| Cache
    Cache -.->|miss| API
    
    API -->|1. Generate candidates| CS
    CS --> INS
    CS --> ONS
    CS --> SPS
    CS -->|deduplicated ~1500| LR
    
    LR --> LF
    LR -->|2. Top 500| HR
    
    HR --> MTM
    HR --> US
    HR -->|3. Top 100 with utility| EE
    
    EE <--> Stats
    EE -->|4. Exploration adjusted| DI
    
    DI -->|5. Diversified| SF
    
    SF --> TD
    SF --> MD
    SF --> SD
    SF --> ND
    SF -->|6. Safe content| Response
    
    Response -->|7. Final results| API
    API -->|cache & return| Cache
    
    API -.->|structured logging| Logger
    Logger --> Tracer
    Logger --> Analyzer
    
    style API fill:#2ecc71,stroke:#27ae60,stroke-width:4px,color:#fff
    style Config fill:#3498db,stroke:#2980b9,stroke-width:2px,color:#fff
    style CS fill:#e74c3c,stroke:#c0392b,stroke-width:2px,color:#fff
    style LR fill:#f39c12,stroke:#d68910,stroke-width:2px,color:#fff
    style HR fill:#e67e22,stroke:#d35400,stroke-width:2px,color:#fff
    style EE fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff
    style DI fill:#16a085,stroke:#138d75,stroke-width:2px,color:#fff
    style SF fill:#c0392b,stroke:#a93226,stroke-width:2px,color:#fff
    style Response fill:#2ecc71,stroke:#27ae60,stroke-width:2px,color:#fff
    style Logger fill:#34495e,stroke:#2c3e50,stroke-width:2px,color:#fff
